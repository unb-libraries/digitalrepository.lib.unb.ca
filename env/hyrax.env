# RAILS_ENV="development"
# BUNDLE_DEPLOYMENT="1"
# BUNDLE_PATH="/usr/local/bundle"
# BUNDLE_WITHOUT=""
# EXECJS_RUNTIME=Node
CH12N_TOOL=fits_servlet
DATABASE_URL=postgresql://digitalrepo@digitalrepository-postgres-lib-unb-ca:5432/digitalrepo?pool=5
# FCREPO_URL=http://fedoraAdmin:fedoraAdmin@fcrepo:8989/fcrepo/rest
# Use internal port 8080 as this is the port that will be exposed within the network
FITS_SERVLET_URL=http://digitalrepository-fits-lib-unb-ca:8080/fits
HYRAX_ACTIVE_JOB_QUEUE=async
REDIS_URL=redis://digitalrepository-redis-lib-unb-ca:6379
SOLR_URL=http://digitalrepository-solr-lib-unb-ca:8983/solr/digitalrepo
VALKYRIE_METADATA_ADAPTER=pg_metadata
VALKYRIE_STORAGE_ADAPTER=versioned_disk_storage

