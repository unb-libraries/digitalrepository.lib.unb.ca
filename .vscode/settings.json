{
  "css.styleSheets": [
    "app/assets/**/*.css"
  ],
  "css.enabledLanguages": [
    "html",
    "erb",
    "html.erb",
    "ruby"
  ],
  "files.exclude": {
    "**/node_modules": true,
    "**/tmp": true,
    "**/log": true,
    "**/vendor": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/tmp": true,
    "**/log": true,
    "**/vendor": true
  },
  "rubyLsp.bundleGemfile": "Gemfile",
  "rubyLsp.indexing": {
    "excludedPatterns": [
      "**/vendor/**",
      "**/node_modules/**",
      "**/tmp/**",
      "**/log/**",
      "**/coverage/**",
      "**/.git/**"
    ]
  },
